# Database Configuration
# For AWS RDS PostgreSQL, use format: postgresql://username:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/grafter_services

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256

# CORS Configuration (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# Debug Mode
DEBUG=False
